<?xml version="1.0" encoding="utf-8"?>
<!--
  Netflix "N" launcher icon foreground.

  Path data is derived from the official Netflix 2016 "N" logo
  (Wikimedia Commons: Netflix_2016_N_logo.svg, viewBox 0 0 551.11 x 1000),
  scaled and centered into the 108x108 adaptive-icon viewport so the
  iconic red "N" sits inside the 72x72 safe zone.

  The N is drawn in three sub-paths (left bar, right bar, diagonal stroke)
  using Netflix's signature red #E50914.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left vertical bar of the N -->
    <path
        android:fillColor="#E50914"
        android:pathData="M 35.737 20.924 L 35.965 87.176 C 40.801 86.245 44.604 86.347 48.896 85.959 L 48.896 21.000 Z" />

    <!-- Right vertical bar of the N -->
    <path
        android:fillColor="#E50914"
        android:pathData="M 59.165 21.000 L 72.324 21.000 L 72.476 87.024 L 59.089 84.818 Z" />

    <!-- Diagonal stroke connecting the two bars -->
    <path
        android:fillColor="#E50914"
        android:pathData="M 35.889 21.000 C 36.194 21.761 58.709 85.807 58.709 85.807 C 62.408 85.781 67.369 86.385 72.248 86.948 L 48.820 21.000 Z" />

</vector>
